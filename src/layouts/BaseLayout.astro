  <title>Boda de Gershell y Yalaniz</title>
</head>
<body class="m-0">
  <audio id="bg-audio" preload="auto" autoplay loop playsinline src="https://3mndwrm41a37dpt7.public.blob.vercel-storage.com/elena_y_david-BF61jgoc.mp3"></audio>
  <slot />
</body>
</html>

<script>
  const audio = document.getElementById('bg-audio');
  if (audio) {
    if (window.location.pathname.startsWith('/blog')) {
      audio.pause();
      audio.currentTime = 0;
    } else {
      audio.muted = false;
      audio.play().catch(() => {});
    }
  }
</script>
