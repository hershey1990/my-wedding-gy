---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout>
  <main class="min-h-screen bg-white">
    <section class="max-w-4xl mx-auto px-4 py-20">
      <h1 class="text-4xl md:text-5xl font-heading text-center mb-2">Nuestro Blog</h1>
      <p class="text-center text-lg mb-12 text-gray-600">Los momentos que compartimos juntos</p>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group block rounded-xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow"
            >
              {
                post.data.image && (
                  <img
                    src={post.data.image}
                    alt=""
                    class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                )
              }
              <div class="p-4">
                <time class="text-sm text-gray-500">
                  {new Intl.DateTimeFormat('es', { dateStyle: 'long' }).format(post.data.date)}
                </time>
                <h2 class="text-xl font-heading mt-1 group-hover:text-[var(--tone-800)] transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-gray-600 mt-2 text-sm line-clamp-3">
                  {post.data.description}
                </p>
                {
                  post.data.tags && (
                    <div class="flex flex-wrap gap-2 mt-3">
                      {post.data.tags.map((tag) => (
                        <span class="text-xs px-2 py-1 rounded-full bg-[var(--color-primary)] text-gray-700">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )
                }
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
