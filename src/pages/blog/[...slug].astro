---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/Header.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug!);
const { Content } = await render(post);
const canonicalURL = `${Astro.url.origin}/blog/${slug}`;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  url={canonicalURL}
  type="article"
>
  <main class="min-h-screen bg-white">
    <Header />
    <article class="max-w-2xl mx-auto px-4 pt-32 pb-20">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-700 mb-8">
        <i class="fa-solid fa-arrow-left"></i>
        Volver al blog
      </a>

      {
        post.data.image && (
          <img
            src={post.data.image}
            alt=""
            class="w-full h-64 md:h-80 object-cover rounded-xl mb-8"
          />
        )
      }

      <time class="text-sm text-gray-500">
        {new Intl.DateTimeFormat('es', { dateStyle: 'long' }).format(post.data.date)}
      </time>

      <h1 class="text-3xl md:text-4xl font-heading mt-2 mb-4">{post.data.title}</h1>

      {
        post.data.tags && (
          <div class="flex flex-wrap gap-2 mb-8">
            {post.data.tags.map((tag) => (
              <span class="text-xs px-2 py-1 rounded-full bg-[var(--color-primary)] text-gray-700">
                #{tag}
              </span>
            ))}
          </div>
        )
      }

      <div class="blog-content">
        <Content />
      </div>

      <!-- Social sharing -->
      <div class="mt-12 pt-8 border-t border-gray-200">
        <p class="text-sm text-gray-500 mb-4">Comparte esta publicación</p>
        <div class="flex gap-3">
          <!-- WhatsApp -->
          <a
            href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' — ' + canonicalURL)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#25D366] text-white text-sm hover:opacity-90 transition-opacity"
          >
            <i class="fa-brands fa-whatsapp"></i>
            WhatsApp
          </a>

          <!-- Facebook -->
          <a
            href={`https://www.facebook.com/sharer.php?u=${encodeURIComponent(canonicalURL)}&quote=${encodeURIComponent(post.data.title)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#1877F2] text-white text-sm hover:opacity-90 transition-opacity"
          >
            <i class="fa-brands fa-facebook"></i>
            Facebook
          </a>

          <!-- Copy link -->
          <button
            id="copy-link-btn"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-100 text-gray-700 text-sm hover:bg-gray-200 transition-colors"
          >
            <i class="fa-solid fa-link"></i>
            <span id="copy-label">Copiar enlace</span>
          </button>
        </div>
      </div>

      <div class="mt-8 pt-8 border-t border-gray-200">
        <a href="/blog" class="inline-flex items-center gap-2 text-gray-500 hover:text-gray-700">
          <i class="fa-solid fa-arrow-left"></i>
          Volver al blog
        </a>
      </div>
    </article>
  </main>
</BaseLayout>

<script>
  const btn = document.getElementById('copy-link-btn');
  const label = document.getElementById('copy-label');
  if (btn) {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        label.textContent = '¡Copiado!';
        setTimeout(() => { label.textContent = 'Copiar enlace'; }, 2000);
      } catch {
        label.textContent = 'Error al copiar';
      }
    });
  }
</script>
