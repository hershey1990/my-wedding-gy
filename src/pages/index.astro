---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/Header.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout>
  <main class="min-h-screen bg-white">
    <Header />

    <!-- Hero -->
    <section class="w-full min-h-[80vh] flex items-center justify-center bg-[var(--color-primary)] pt-32 pb-20">
      <div class="max-w-3xl mx-auto text-center px-4">
        <img
          src="https://3mndwrm41a37dpt7.public.blob.vercel-storage.com/us.webp"
          alt="Gershell & Yalaniz"
          class="w-40 h-40 md:w-52 md:h-52 rounded-full object-cover mx-auto mb-8 border-4 border-white shadow-lg"
        />
        <h1 class="text-4xl md:text-6xl font-heading mb-4">Gershell & Yalaniz</h1>
        <p class="text-lg md:text-xl text-gray-600 max-w-xl mx-auto leading-relaxed">
          Bienvenidos a nuestro rincón. Aquí documentamos nuestras aventuras, recuerdos y todo lo que construimos juntos desde aquel 1 de marzo de 2026.
        </p>
        <div class="flex flex-wrap gap-4 justify-center mt-8">
          <a href="/blog" class="px-6 py-3 rounded-lg bg-[var(--tone-800)] text-white hover:bg-[var(--shade-800)] transition-colors">
            Leer el blog
          </a>
          <a href="/boda" class="px-6 py-3 rounded-lg border border-[var(--tone-800)] text-[var(--tone-800)] hover:bg-[var(--tone-100)] transition-colors">
            Nuestra boda
          </a>
        </div>
      </div>
    </section>

    <!-- Latest posts -->
    <section class="w-full py-20 px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-heading text-center mb-2">Últimas Aventuras</h2>
        <p class="text-center text-gray-600 mb-12">Los momentos que hemos vivido juntos</p>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {
            posts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="group block rounded-xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow"
              >
                {
                  post.data.image && (
                    <img
                      src={post.data.image}
                      alt=""
                      class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  )
                }
                <div class="p-5">
                  <time class="text-sm text-gray-500">
                    {new Intl.DateTimeFormat('es', { dateStyle: 'long' }).format(post.data.date)}
                  </time>
                  <h3 class="text-xl font-heading mt-1 group-hover:text-[var(--tone-800)] transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-gray-600 mt-2 text-sm line-clamp-2">
                    {post.data.description}
                  </p>
                  {
                    post.data.tags && (
                      <div class="flex flex-wrap gap-2 mt-3">
                        {post.data.tags.map((tag) => (
                          <span class="text-xs px-2 py-1 rounded-full bg-[var(--color-primary)] text-gray-700">
                            #{tag}
                          </span>
                        ))}
                      </div>
                    )
                  }
                </div>
              </a>
            ))
          }
        </div>

        {
          posts.length === 0 && (
            <p class="text-center text-gray-500">Pronto compartiremos nuestras primeras historias.</p>
          )
        }
      </div>
    </section>

    <!-- About / Wedding CTA -->
    <section class="w-full py-20 px-4 bg-[var(--color-primary)]">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-heading mb-4">Nuestra historia comienza aquí</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg leading-relaxed mb-8">
          El 1 de marzo de 2026 nos juramos amor eterno en Esquipulas. Desde entonces, cada día es una nueva página que escribir. ¿Quieres ver cómo empezó todo?
        </p>
        <a
          href="/boda"
          class="inline-block px-8 py-3 rounded-lg bg-[var(--tone-800)] text-white hover:bg-[var(--shade-800)] transition-colors text-lg"
        >
          Revive nuestra boda
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
