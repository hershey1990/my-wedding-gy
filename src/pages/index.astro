---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/Header.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout>
  <main class="min-h-screen bg-white">
    <Header dark />

    <!-- Hero Slideshow -->
    <section class="relative w-full h-screen overflow-hidden">
      <!-- Slides -->
      {["001", "050", "100", "150", "200"].map((num, i) => (
        <div class={`hero-slide absolute inset-0 transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}>
          <img
            src={`/gallery/${num}.webp`}
            alt=""
            class="w-full h-full object-cover"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
          <div class="absolute inset-0 bg-black/50"></div>
        </div>
      ))}

      <!-- Overlay content -->
      <div class="absolute inset-0 flex items-center justify-center z-10">
        <div class="text-center px-4">
          <img
            src="https://3mndwrm41a37dpt7.public.blob.vercel-storage.com/us.webp"
            alt="Gershell & Yalaniz"
            class="w-28 h-28 md:w-36 md:h-36 rounded-full object-cover mx-auto mb-6 border-4 border-white/80 shadow-xl"
          />
          <h1 class="text-4xl md:text-6xl font-heading mb-4" style="color: #fff; text-shadow: 0 2px 8px rgba(0,0,0,0.6)">Gershell & Yalaniz</h1>
          <p class="text-lg md:text-xl max-w-xl mx-auto leading-relaxed" style="color: #fff; text-shadow: 0 2px 6px rgba(0,0,0,0.7)">
            Bienvenidos a nuestro rincón. Aquí documentamos nuestras aventuras, recuerdos y todo lo que construimos juntos desde aquel 1 de marzo de 2026.
          </p>
          <div class="flex flex-wrap gap-4 justify-center mt-8">
            <a href="/blog" class="px-6 py-3 rounded-lg bg-[var(--tone-800)] hover:bg-[var(--shade-800)] transition-colors shadow-lg" style="color: #fff">
              Leer el blog
            </a>
            <a href="/galeria" class="px-6 py-3 rounded-lg border-2 border-white hover:bg-white/20 transition-colors" style="color: #fff; text-shadow: 0 1px 4px rgba(0,0,0,0.5)">
              Ver galería
            </a>
          </div>
        </div>
      </div>

      <!-- Slide indicators -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-2 z-10">
        {["001", "050", "100", "150", "200"].map((_, i) => (
          <button
            type="button"
            class={`slide-dot w-3 h-3 rounded-full transition-colors cursor-pointer ${i === 0 ? 'bg-white' : 'bg-white/50'}`}
            data-index={i}
            aria-label={`Foto ${i + 1}`}
          ></button>
        ))}
      </div>
    </section>

    <!-- Latest posts -->
    <section class="w-full py-20 px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-heading text-center mb-2">Últimas Aventuras</h2>
        <p class="text-center text-gray-600 mb-12">Los momentos que hemos vivido juntos</p>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {
            posts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="group block rounded-xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow"
              >
                {
                  post.data.image && (
                    <img
                      src={post.data.image}
                      alt=""
                      class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  )
                }
                <div class="p-5">
                  <time class="text-sm text-gray-500">
                    {new Intl.DateTimeFormat('es', { dateStyle: 'long' }).format(post.data.date)}
                  </time>
                  <h3 class="text-xl font-heading mt-1 group-hover:text-[var(--tone-800)] transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-gray-600 mt-2 text-sm line-clamp-2">
                    {post.data.description}
                  </p>
                  {
                    post.data.tags && (
                      <div class="flex flex-wrap gap-2 mt-3">
                        {post.data.tags.map((tag) => (
                          <span class="text-xs px-2 py-1 rounded-full bg-[var(--color-primary)] text-gray-700">
                            #{tag}
                          </span>
                        ))}
                      </div>
                    )
                  }
                </div>
              </a>
            ))
          }
        </div>

        {
          posts.length === 0 && (
            <p class="text-center text-gray-500">Pronto compartiremos nuestras primeras historias.</p>
          )
        }
      </div>
    </section>

    <!-- About / Wedding CTA -->
    <section class="w-full py-20 px-4 bg-[var(--color-primary)]">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-heading mb-4">Nuestra historia comienza aquí</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg leading-relaxed mb-8">
          El 1 de marzo de 2026 nos juramos amor eterno en Esquipulas. Desde entonces, cada día es una nueva página que escribir. ¿Quieres ver cómo empezó todo?
        </p>
        <a
          href="/boda"
          class="inline-block px-8 py-3 rounded-lg bg-[var(--tone-800)] text-white hover:bg-[var(--shade-800)] transition-colors text-lg"
        >
          Revive nuestra boda
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  // Hero slideshow
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.slide-dot');
  let currentSlide = 0;
  const totalSlides = slides.length;

  function showSlide(index) {
    slides.forEach((s, i) => {
      s.classList.toggle('opacity-100', i === index);
      s.classList.toggle('opacity-0', i !== index);
    });
    dots.forEach((d, i) => {
      d.classList.toggle('bg-white', i === index);
      d.classList.toggle('bg-white/50', i !== index);
    });
    currentSlide = index;
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => showSlide(parseInt(dot.dataset.index)));
  });

  setInterval(() => showSlide((currentSlide + 1) % totalSlides), 5000);
</script>
