---
const isBoda = Astro.url.pathname.startsWith('/boda');
const { dark = false } = Astro.props as { dark?: boolean };
---

<header id="site-header" class={`w-full fixed top-0 md:pt-10 pt-4 left-0 z-20 transition-all duration-300 bg-transparent ${dark ? 'header-dark' : ''}`}>
  <nav class="w-full h-full flex items-center justify-center relative">
    <ul class="list-none menu text-center [&>li]:inline-block [&>li]:mx-2 md:[&>li]:mx-4">
      <li><a href="/">Inicio</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/galeria">Galería</a></li>
      <li><a href="/boda">Nuestra Boda</a></li>
      {
        isBoda && (
          <>
            <li><a href="/boda#our-votes">Nuestra Historia</a></li>
            <li><a href="/boda#details">Detalles</a></li>
            <li><a href="/boda#gifts">Regalos</a></li>
            <li><a href="/boda#dress-code">Vestimenta</a></li>
          </>
        )
      }
    </ul>
  </nav>
</header>

<style>
  #site-header.scrolled {
    background-color: rgb(255 255 255 / 0.7);
    backdrop-filter: blur(4px);
  }
  #site-header nav a.active {
    color: var(--shade-900);
  }

  /* White menu text for dark backgrounds (homepage slideshow) */
  #site-header.header-dark nav a {
    color: #fff;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
  }
  /* Revert to dark text when header becomes solid */
  #site-header.header-dark.scrolled nav a {
    color: var(--color-font-primary);
    text-shadow: none;
  }
  #site-header.header-dark.scrolled nav a.active {
    color: var(--shade-900);
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const links = document.querySelectorAll('#site-header nav a');

  const handleScroll = () => {
    const scrolled = window.scrollY > window.innerHeight;
    header.classList.toggle('scrolled', scrolled);

    const offset = 140;
    const sections = ['our-votes', 'details', 'gifts', 'rsvp', 'dress-code'];
    let current = 'home';

    for (const id of sections) {
      const el = document.getElementById(id);
      if (!el) continue;
      const top = el.getBoundingClientRect().top + window.scrollY;
      if (window.scrollY + offset >= top) {
        current = id;
      }
    }

    links.forEach(a => a.classList.toggle('active', a.getAttribute('href') === `#${current}`));
  };

  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });
</script>
